---
export const prerender = false;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Event Collections</title>
    <style is:global>
      :root {
        --bg: #eef2f7;
        --card: #ffffff;
        --text: #111827;
        --muted: #4b5563;
        --line: #b6becb;
        --accent: #b91c1c;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: "Segoe UI", -apple-system, BlinkMacSystemFont, sans-serif;
      }
      main {
        width: min(1200px, 100% - 2rem);
        margin: 1.75rem auto 3rem;
      }
      h1 { margin: 0; font-size: clamp(1.55rem, 2.4vw, 2rem); }
      .muted { color: var(--muted); }
      .panel {
        margin-top: 1rem;
        padding: 1.15rem 1.2rem;
        border: 1px solid var(--line);
        border-radius: 0.85rem;
        background: var(--card);
        box-shadow: 0 2px 8px rgba(15, 23, 42, 0.05);
      }
      .toolbar {
        display: flex;
        gap: 0.75rem;
        align-items: center;
        flex-wrap: wrap;
      }
      .toolbar input {
        min-height: 2.5rem;
        border: 1px solid var(--line);
        border-radius: 0.55rem;
        padding: 0 0.7rem;
        font-size: 0.97rem;
        min-width: min(360px, 100%);
      }
      .year-group { margin-top: 1.25rem; }
      .year-head {
        margin: 0 0 0.65rem;
        font-size: 1.12rem;
        color: #1f2937;
      }
      .collection-list {
        margin: 0;
        padding: 0;
        list-style: none;
        display: grid;
        gap: 0.6rem;
      }
      .collection-item a {
        display: grid;
        grid-template-columns: minmax(180px, 1fr) repeat(4, auto);
        gap: 0.75rem;
        align-items: center;
        text-decoration: none;
        color: inherit;
        border: 1px solid var(--line);
        border-radius: 0.6rem;
        background: #fff;
        padding: 0.9rem;
        box-shadow: 0 1px 3px rgba(15, 23, 42, 0.05);
        transition: border-color 120ms ease, box-shadow 120ms ease, transform 120ms ease;
      }
      .collection-item a:hover {
        border-color: var(--accent);
        box-shadow: 0 8px 20px rgba(15, 23, 42, 0.08);
        transform: translateY(-1px);
      }
      .event-id { font-weight: 700; }
      .metric {
        display: grid;
        justify-items: end;
        min-width: 92px;
        border-left: 1px solid #e5e7eb;
        padding-left: 0.7rem;
      }
      .metric-label { font-size: 0.72rem; color: var(--muted); text-transform: uppercase; }
      .metric-value { font-weight: 700; }
      .chip {
        display: inline-flex;
        align-items: center;
        min-height: 1.6rem;
        border: 1px solid #fecaca;
        border-radius: 999px;
        padding: 0 0.55rem;
        font-size: 0.74rem;
        font-weight: 700;
        color: #991b1b;
        background: #fff1f2;
        margin-top: 0.35rem;
      }
      #status.error { color: #991b1b; font-weight: 700; }
      @media (max-width: 780px) {
        main { width: min(1200px, 100% - 1rem); }
        .panel { padding: 0.8rem; }
        .collection-item a {
          grid-template-columns: 1fr 1fr;
          gap: 0.45rem 0.75rem;
        }
        .metric {
          justify-items: start;
          border-left: 0;
          padding-left: 0;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <h1>Event Collections</h1>
      <p class="muted">Uebersicht aller Events. Klick auf ein Event oeffnet die Detailtabelle.</p>

      <section class="panel">
        <div class="toolbar">
          <input id="search" type="text" placeholder="Event suchen (z. B. kerwa oder dart)" />
        </div>
        <p id="status" class="muted">Lade ...</p>
        <div id="groups"></div>
      </section>
    </main>

    <script>
      // @ts-nocheck
      const token = new URLSearchParams(window.location.search).get("token") || "";
      const els = {
        search: document.getElementById("search"),
        status: document.getElementById("status"),
        groups: document.getElementById("groups"),
      };
      let rows = [];

      function setStatus(text, error = false) {
        els.status.textContent = text;
        els.status.className = error ? "error" : "muted";
      }

      function grouped(rowsInput) {
        const byYear = new Map();
        for (const row of rowsInput) {
          const list = byYear.get(row.year) ?? [];
          list.push(row);
          byYear.set(row.year, list);
        }
        return Array.from(byYear.entries()).sort((a, b) => Number(b[0]) - Number(a[0]));
      }

      function render() {
        const q = els.search.value.trim().toLowerCase();
        const filtered = q
          ? rows.filter((row) => row.eventId.toLowerCase().includes(q))
          : rows;
        const groups = grouped(filtered);

        if (!groups.length) {
          els.groups.innerHTML = "<p class='muted'>Keine Events gefunden.</p>";
          return;
        }

        els.groups.innerHTML = groups
          .map(([year, entries]) => {
            const list = entries
              .map((row) => {
                const href = `/admin/event-signups/${encodeURIComponent(row.eventId)}?token=${encodeURIComponent(token)}`;
                return `
                  <li class="collection-item">
                    <a href="${href}">
                      <div>
                        <div class="event-id">${row.eventId}</div>
                        <span class="chip">Detailansicht</span>
                        <div class="muted">Letzte Anmeldung: ${new Date(row.lastSignupAt).toLocaleString("de-DE")}</div>
                      </div>
                      <div class="metric"><span class="metric-label">Anmeldungen</span><span class="metric-value">${row.signups}</span></div>
                      <div class="metric"><span class="metric-label">Personen</span><span class="metric-value">${row.partySize}</span></div>
                      <div class="metric"><span class="metric-label">Items</span><span class="metric-value">${row.items}</span></div>
                      <div class="metric"><span class="metric-label">Jahr</span><span class="metric-value">${row.year}</span></div>
                    </a>
                  </li>
                `;
              })
              .join("");
            return `<section class="year-group"><h2 class="year-head">${year}</h2><ul class="collection-list">${list}</ul></section>`;
          })
          .join("");
      }

      async function load() {
        if (!token) {
          setStatus("Kein Token in URL. Verwenden: /admin/event-signups?token=...", true);
          return;
        }
        const response = await fetch(`/api/admin/event-signups.collections?token=${encodeURIComponent(token)}`);
        const result = await response.json();
        if (!response.ok || !result.ok) {
          throw new Error(result.message || "Collections konnten nicht geladen werden.");
        }
        rows = result.rows;
        render();
        setStatus(`${rows.length} Events geladen.`);
      }

      els.search.addEventListener("input", render);
      load().catch((error) => {
        setStatus(error instanceof Error ? error.message : "Fehler beim Laden", true);
      });
    </script>
  </body>
</html>

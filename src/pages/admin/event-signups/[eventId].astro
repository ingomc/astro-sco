---
import SignupsFilters from "../../../components/admin/SignupsFilters.astro";
import SignupsStats from "../../../components/admin/SignupsStats.astro";
import SignupsTable from "../../../components/admin/SignupsTable.astro";

export const prerender = false;
const fixedEventId = decodeURIComponent(Astro.params.eventId ?? "").trim();
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Event Signups Detail</title>
    <style>
      :root {
        --bg: #eef2f7;
        --card: #ffffff;
        --text: #111827;
        --muted: #4b5563;
        --line: #b6becb;
        --line-soft: #cfd6e2;
        --accent: #b91c1c;
        --accent-strong: #991b1b;
        --accent-soft: #fee2e2;
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: "Segoe UI", -apple-system, BlinkMacSystemFont, sans-serif;
      }
      main {
        width: min(1200px, 100% - 2rem);
        margin: 1.75rem auto 3rem;
      }
      h1 {
        margin: 0;
        font-size: clamp(1.55rem, 2.4vw, 2rem);
      }
      .topbar {
        display: block;
        margin-bottom: 1rem;
      }
      .muted {
        color: var(--muted);
      }
      .panel {
        margin-top: 1rem;
        padding: 1.15rem 1.2rem;
        border: 1px solid var(--line);
        border-radius: 0.85rem;
        background: var(--card);
        box-shadow: 0 2px 8px rgba(15, 23, 42, 0.05);
      }
      .error {
        color: #991b1b;
        font-weight: 700;
      }
      .ok {
        color: #166534;
        font-weight: 700;
      }
      @media (max-width: 640px) {
        main {
          width: min(1200px, 100% - 1rem);
        }
        .panel {
          padding: 0.8rem;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <div class="topbar">
        <div>
          <h1>Event Signups Dashboard</h1>
          <p class="muted">Event-Detailansicht fuer {fixedEventId}. Suche, Filter, Edit, CSV und Bulk-Loeschen.</p>
          <p class="muted"><a href={`/admin/event-signups?token=${Astro.url.searchParams.get("token") ?? ""}`}>Alle Events</a></p>
        </div>
      </div>

      <SignupsFilters />
      <SignupsStats />
      <SignupsTable />
    </main>

    <script define:vars={{ fixedEventId }}>
      // @ts-nocheck
      const state = {
        rows: [],
        selected: new Set(),
        page: 1,
        totalPages: 1,
        total: 0,
        editingId: null,
        token: new URLSearchParams(window.location.search).get("token") || "",
        fixedEventId,
      };

      const els = {
        q: document.getElementById("q"),
        eventId: document.getElementById("eventId"),
        kind: document.getElementById("kind"),
        createdAfter: document.getElementById("createdAfter"),
        createdBefore: document.getElementById("createdBefore"),
        sortBy: document.getElementById("sortBy"),
        sortDirection: document.getElementById("sortDirection"),
        pageSize: document.getElementById("pageSize"),
        apply: document.getElementById("apply"),
        reset: document.getElementById("reset"),
        bulkDelete: document.getElementById("bulk-delete"),
        csvLink: document.getElementById("csv-link"),
        status: document.getElementById("status"),
        stats: document.getElementById("stats"),
        eventsBreakdown: document.getElementById("events-breakdown"),
        rows: document.getElementById("rows"),
        prev: document.getElementById("prev"),
        next: document.getElementById("next"),
        pageLabel: document.getElementById("page-label"),
        selectAll: document.getElementById("select-all"),
      };

      function setStatus(message, isError = false) {
        els.status.textContent = message;
        els.status.className = isError ? "error" : "muted";
      }

      function getFilters() {
        const params = new URLSearchParams();
        if (state.token) {
          params.set("token", state.token);
        }

        const values = {
          q: els.q.value.trim(),
          eventId: state.fixedEventId,
          kind: els.kind.value,
          createdAfter: els.createdAfter.value ? new Date(els.createdAfter.value).toISOString() : "",
          createdBefore: els.createdBefore.value ? new Date(els.createdBefore.value).toISOString() : "",
          sortBy: els.sortBy.value,
          sortDirection: els.sortDirection.value,
          pageSize: els.pageSize.value,
          page: String(state.page),
        };

        for (const [key, value] of Object.entries(values)) {
          if (value) {
            params.set(key, value);
          }
        }

        return params;
      }

      function updateLinks(params) {
        els.csvLink.href = `/api/admin/event-signups.csv?${params.toString()}`;
      }

      function renderStats(stats) {
        const cards = [
          { label: "Anmeldungen", value: stats.totalSignups },
          { label: "Personen", value: stats.totalPartySize },
          { label: "Items", value: stats.totalItems },
          { label: "Events", value: stats.byEvent.length },
        ];

        els.stats.innerHTML = cards
          .map(
            (card) =>
              `<article class="stat"><span class="stat-label">${card.label}</span><strong class="stat-value">${card.value}</strong></article>`,
          )
          .join("");

        els.eventsBreakdown.innerHTML = stats.byEvent.length
          ? stats.byEvent
              .map(
                (eventStat) =>
                  `<span>${eventStat.eventId}: ${eventStat.signups} Anm. / ${eventStat.partySize} Pers.</span>`,
              )
              .join("")
          : "<span>Keine Event-Daten vorhanden.</span>";
      }

      function renderRows() {
        if (!state.rows.length) {
          els.rows.innerHTML = '<tr><td colspan="12">Keine Datensaetze gefunden.</td></tr>';
          return;
        }

        els.rows.innerHTML = state.rows
          .map((row) => {
            const checked = state.selected.has(row.id) ? "checked" : "";
            const edit = state.editingId === row.id;
            const itemSummary = row.items.length
              ? `<ul class="items-list">${row.items
                  .map((item) => `<li>${item.quantity}x ${item.label}</li>`)
                  .join("")}</ul>`
              : "-";
            const itemInputs = row.items
              .map(
                (item) =>
                  `<li><label>${item.label}<input data-item-id="${item.itemId}" type="number" min="0" max="99" value="${item.quantity}" /></label></li>`,
              )
              .join("");

            return `<tr data-row-id="${row.id}">
              <td><input type="checkbox" data-select-id="${row.id}" ${checked} /></td>
              <td>${new Date(row.createdAt).toLocaleString("de-DE")}</td>
              <td>${row.eventId}</td>
              <td><span class="kind-pill ${row.kind}">${row.kind}</span></td>
              <td>${
                edit
                  ? `<input data-edit="name" value="${row.name.replaceAll('"', '&quot;')}" />`
                  : row.name
              }</td>
              <td>${
                edit
                  ? `<input data-edit="email" value="${row.email.replaceAll('"', '&quot;')}" />`
                  : row.email
              }</td>
              <td>${
                edit
                  ? `<textarea data-edit="notes" rows="2" maxlength="1000">${(row.notes || "").replaceAll("<", "&lt;").replaceAll(">", "&gt;")}</textarea>`
                  : row.notes || "-"
              }</td>
              <td>${
                edit
                  ? `<input data-edit="partySize" type="number" min="1" max="99" value="${row.partySize}" />`
                  : row.partySize
              }</td>
              <td>${edit ? `<ul class="items-edit-list">${itemInputs}</ul>` : itemSummary}</td>
              <td>${row.totalItems}</td>
              <td><strong>${row.id}</strong></td>
              <td class="actions">
                <div class="actions-row">
                  ${
                    edit
                      ? `<button data-save="${row.id}">Speichern</button><button data-cancel="${row.id}">Abbrechen</button>`
                      : `<button data-edit-row="${row.id}">Edit</button>`
                  }
                  <button data-delete="${row.id}">Loeschen</button>
                </div>
              </td>
            </tr>`;
          })
          .join("");
      }

      async function loadStats(params) {
        const response = await fetch(`/api/admin/event-signups.stats?${params.toString()}`);
        const result = await response.json();
        if (!response.ok || !result.ok) {
          throw new Error(result.message || "Statistik konnte nicht geladen werden.");
        }

        renderStats(result.stats);
      }

      async function loadList() {
        const params = getFilters();
        updateLinks(params);
        setStatus("Lade ...");

        const response = await fetch(`/api/admin/event-signups.list?${params.toString()}`);
        const result = await response.json();

        if (!response.ok || !result.ok) {
          throw new Error(result.message || "Liste konnte nicht geladen werden.");
        }

        state.rows = result.rows;
        state.page = result.page;
        state.totalPages = result.totalPages;
        state.total = result.total;
        state.selected.clear();
        state.editingId = null;

        renderRows();
        els.pageLabel.textContent = `Seite ${state.page} / ${state.totalPages} (${state.total})`;
        await loadStats(params);
        setStatus(`${state.total} Datensaetze geladen.`);
      }

      async function deleteOne(id) {
        if (!window.confirm(`Datensatz ${id} wirklich loeschen?`)) {
          return;
        }

        const params = new URLSearchParams();
        if (state.token) {
          params.set("token", state.token);
        }

        params.set("id", id);
        const response = await fetch(`/api/admin/event-signups.mutation?${params.toString()}`, {
          method: "DELETE",
        });
        const result = await response.json();

        if (!response.ok || !result.ok) {
          throw new Error(result.message || "Loeschen fehlgeschlagen.");
        }

        await loadList();
        setStatus("Datensatz geloescht.");
      }

      async function saveEdit(id, rowEl) {
        const name = rowEl.querySelector('[data-edit="name"]').value;
        const email = rowEl.querySelector('[data-edit="email"]').value;
        const notes = rowEl.querySelector('[data-edit="notes"]').value;
        const partySize = Number.parseInt(rowEl.querySelector('[data-edit="partySize"]').value, 10);
        const items = {};

        for (const input of rowEl.querySelectorAll("[data-item-id]")) {
          const itemId = input.getAttribute("data-item-id");
          const qty = Number.parseInt(input.value, 10);
          items[itemId] = Number.isFinite(qty) ? qty : 0;
        }

        const params = new URLSearchParams();
        if (state.token) {
          params.set("token", state.token);
        }

        params.set("id", id);
        const response = await fetch(`/api/admin/event-signups.mutation?${params.toString()}`, {
          method: "PATCH",
          headers: {
            "content-type": "application/json",
          },
          body: JSON.stringify({ name, email, notes, partySize, items }),
        });
        const result = await response.json();

        if (!response.ok || !result.ok) {
          throw new Error(result.message || "Speichern fehlgeschlagen.");
        }

        state.editingId = null;
        await loadList();
        setStatus("Datensatz gespeichert.");
      }

      async function bulkDelete() {
        const ids = Array.from(state.selected);
        if (!ids.length) {
          setStatus("Keine Auswahl vorhanden.", true);
          return;
        }

        if (!window.confirm(`${ids.length} Datensaetze wirklich loeschen?`)) {
          return;
        }

        const params = new URLSearchParams();
        if (state.token) {
          params.set("token", state.token);
        }

        const response = await fetch(`/api/admin/event-signups.bulk-delete?${params.toString()}`, {
          method: "POST",
          headers: {
            "content-type": "application/json",
          },
          body: JSON.stringify({ ids }),
        });
        const result = await response.json();

        if (!response.ok || !result.ok) {
          throw new Error(result.message || "Bulk-Loeschen fehlgeschlagen.");
        }

        await loadList();
        setStatus(`${result.deletedCount} Datensaetze geloescht.`);
      }

      els.apply.addEventListener("click", async () => {
        state.page = 1;
        try {
          await loadList();
        } catch (error) {
          setStatus(error instanceof Error ? error.message : "Fehler beim Laden", true);
        }
      });

      els.reset.addEventListener("click", async () => {
        els.q.value = "";
        els.eventId.value = state.fixedEventId;
        els.kind.value = "";
        els.createdAfter.value = "";
        els.createdBefore.value = "";
        els.sortBy.value = "createdAt";
        els.sortDirection.value = "desc";
        els.pageSize.value = "25";
        state.page = 1;

        try {
          await loadList();
        } catch (error) {
          setStatus(error instanceof Error ? error.message : "Fehler beim Laden", true);
        }
      });

      els.prev.addEventListener("click", async () => {
        if (state.page <= 1) {
          return;
        }
        state.page -= 1;

        try {
          await loadList();
        } catch (error) {
          setStatus(error instanceof Error ? error.message : "Fehler beim Laden", true);
        }
      });

      els.next.addEventListener("click", async () => {
        if (state.page >= state.totalPages) {
          return;
        }
        state.page += 1;

        try {
          await loadList();
        } catch (error) {
          setStatus(error instanceof Error ? error.message : "Fehler beim Laden", true);
        }
      });

      els.bulkDelete.addEventListener("click", async () => {
        try {
          await bulkDelete();
        } catch (error) {
          setStatus(error instanceof Error ? error.message : "Fehler beim Bulk-Loeschen", true);
        }
      });

      els.selectAll.addEventListener("change", (event) => {
        if (event.target.checked) {
          for (const row of state.rows) {
            state.selected.add(row.id);
          }
        } else {
          state.selected.clear();
        }

        renderRows();
      });

      els.rows.addEventListener("change", (event) => {
        const target = event.target;
        if (!(target instanceof HTMLInputElement)) {
          return;
        }

        const id = target.getAttribute("data-select-id");
        if (!id) {
          return;
        }

        if (target.checked) {
          state.selected.add(id);
        } else {
          state.selected.delete(id);
        }
      });

      els.rows.addEventListener("click", async (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) {
          return;
        }

        const editId = target.getAttribute("data-edit-row");
        if (editId) {
          state.editingId = editId;
          renderRows();
          return;
        }

        const cancelId = target.getAttribute("data-cancel");
        if (cancelId) {
          state.editingId = null;
          renderRows();
          return;
        }

        const deleteId = target.getAttribute("data-delete");
        if (deleteId) {
          try {
            await deleteOne(deleteId);
          } catch (error) {
            setStatus(error instanceof Error ? error.message : "Fehler beim Loeschen", true);
          }
          return;
        }

        const saveId = target.getAttribute("data-save");
        if (!saveId) {
          return;
        }

        const rowEl = target.closest("tr");
        if (!(rowEl instanceof HTMLElement)) {
          return;
        }

        try {
          await saveEdit(saveId, rowEl);
        } catch (error) {
          setStatus(error instanceof Error ? error.message : "Fehler beim Speichern", true);
        }
      });

      (async () => {
        if (!state.token) {
          setStatus("Kein Token in URL. Verwenden: /admin/event-signups?token=...", true);
          return;
        }

        try {
          await loadList();
        } catch (error) {
          setStatus(error instanceof Error ? error.message : "Fehler beim Initialisieren", true);
        }
      })();

      els.eventId.value = state.fixedEventId;
      els.eventId.readOnly = true;
      els.eventId.setAttribute("aria-readonly", "true");
    </script>
  </body>
</html>

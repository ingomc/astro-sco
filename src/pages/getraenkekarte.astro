---
import App from "../layouts/App.astro";
import HpCard from "../components/HpCard.astro";
import HpStage from "../components/HpStage.astro";

const title = "Getränkekarte - SCO-OGV Oberfüllbach";
const description = "Aktuelle Getränkekarte im Sportheim des SCO-OGV Oberfüllbach.";

const sectionMeta = {
  Bier: { icon: "beer" },
  "Alkoholfreie Getränke": { icon: "bottle" },
  "Wein und Spirituosen": { icon: "glass" }
} as const;

const slugify = (value: string) =>
  value
    .toLowerCase()
    .replaceAll("ä", "ae")
    .replaceAll("ö", "oe")
    .replaceAll("ü", "ue")
    .replaceAll("ß", "ss")
    .replaceAll(" ", "-");

const menuSections = [
  {
    name: "Bier",
    rows: [
      { drink: "Bier, Radler, Weizen", volume: "1,0 l", price: "5,70 EUR" },
      { drink: "Bier, Radler, Weizen", volume: "0,5 l", price: "3,00 EUR" },
      { drink: "Bier, Radler, Weizen", volume: "0,25 l", price: "1,70 EUR" },
      { drink: "Leichtbier, alkoholfreies Weizenbier", volume: "0,5 l", price: "3,00 EUR" }
    ]
  },
  {
    name: "Alkoholfreie Getränke",
    rows: [
      { drink: "Limo, Spezi", volume: "0,5 l", price: "2,50 EUR" },
      { drink: "Cola", volume: "0,5 l", price: "2,50 EUR" },
      { drink: "Apfelsaftschorle", volume: "0,5 l", price: "2,50 EUR" },
      { drink: "Mineralwasser", volume: "0,5 l", price: "2,50 EUR" }
    ]
  },
  {
    name: "Wein und Spirituosen",
    rows: [
      { drink: "Frankenwein, Rotwein", volume: "0,2 l", price: "2,70 EUR" },
      { drink: "Frankenwein, Rotwein", volume: "0,1 l", price: "1,40 EUR" },
      { drink: "Weinschorle", volume: "0,5 l", price: "3,50 EUR" },
      { drink: "Weinschorle", volume: "0,25 l", price: "1,80 EUR" },
      { drink: "Schnaps", volume: "0,02 l", price: "1,50 EUR" }
    ]
  }
] as const;
---

<App title={title} description={description}>
  <div class="screen-only">
    <HpStage image="/src/media/buehne-sportheim.jpg" title="Getränkekarte" />
  </div>

  <div class="container mx-auto px-4 py-6 md:py-10">
    <div class="menu-shell rounded-2xl border border-slate-200 p-4 md:p-8">
      <header class="mb-6 md:mb-8">
        <div class="menu-header">
          <div class="brand-lockup">
            <img
              src="/logos/sco-logo.svg"
              alt="SCO-OGV Oberfüllbach Logo"
              class="brand-logo"
              loading="eager"
              decoding="async"
            />
            <div>
              <p class="eyebrow">Sportheim SCO-OGV Oberfüllbach</p>
              <h2 class="text-2xl md:text-3xl font-bold text-slate-900">Getränkekarte</h2>
              <p class="mt-2 max-w-2xl text-slate-700">
                Frisch, fair und unkompliziert - für Spieltag, Feier und gemütliches Beisammensein.
              </p>
            </div>
          </div>
        </div>
      </header>

      <div class="grid gap-4 md:gap-6" role="list" aria-label="Getränkekarte nach Kategorien">
        {
          menuSections.map((section) => {
            const id = `section-${slugify(section.name)}`;
            const meta = sectionMeta[section.name];

            return (
            <section role="listitem" aria-labelledby={id} class="print-section">
              <HpCard>
                <div slot="title" class="flex items-center justify-between gap-3">
                  <h3 id={id} class="flex items-center gap-2 font-bold text-lg text-slate-900">
                    <span class="section-icon" aria-hidden="true">
                      {
                        meta.icon === "beer" && (
                          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M6 6h8v10a3 3 0 0 1-3 3H9a3 3 0 0 1-3-3z"></path>
                            <path d="M14 9h2a2 2 0 0 1 0 4h-2"></path>
                            <path d="M8 4v2M11 4v2"></path>
                          </svg>
                        )
                      }
                      {
                        meta.icon === "bottle" && (
                          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M10 3h4"></path>
                            <path d="M11 3v3l-3 4v8a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2v-8l-3-4V3"></path>
                          </svg>
                        )
                      }
                      {
                        meta.icon === "glass" && (
                          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M7 4h10l-2 7a3 3 0 0 1-3 2 3 3 0 0 1-3-2z"></path>
                            <path d="M12 13v5"></path>
                            <path d="M9 20h6"></path>
                          </svg>
                        )
                      }
                    </span>
                    {section.name}
                  </h3>
                </div>

                <div class="overflow-x-auto">
                  <table class="menu-table">
                    <caption class="sr-only">{section.name}</caption>
                    <colgroup>
                      <col class="col-drink" />
                      <col class="col-volume" />
                      <col class="col-price" />
                    </colgroup>
                    <thead>
                      <tr>
                        <th scope="col">Getränk</th>
                        <th scope="col">Menge</th>
                        <th scope="col" class="text-right">Preis</th>
                      </tr>
                    </thead>
                    <tbody>
                      {
                        section.rows.map((row) => (
                          <tr>
                            <th scope="row">{row.drink}</th>
                            <td>{row.volume}</td>
                            <td class="text-right whitespace-nowrap">{row.price}</td>
                          </tr>
                        ))
                      }
                    </tbody>
                  </table>
                </div>
              </HpCard>
            </section>
          )})
        }
      </div>

      <footer class="mt-6 md:mt-8 border-t border-slate-200 pt-4 text-sm text-slate-600 legal-notes" aria-label="Rechtliche Hinweise">
        <p>Alle Preise in EUR inkl. gesetzlicher MwSt. Stand: 14. Mai 2026. Änderungen und Irrtümer vorbehalten.</p>
        <p>Die Angaben auf dieser Website sind unverbindlich; maßgeblich ist die vor Ort ausgehängte Getränkekarte.</p>
        <p>Informationen zu Allergenen und Zusatzstoffen erhalten Sie beim Personal.</p>
        <p>Ausschank alkoholischer Getränke gemäß Jugendschutzgesetz.</p>
      </footer>

    </div>
  </div>
</App>

<style>
  .screen-only {
    display: block;
  }

  .menu-shell {
    background: #ffffff;
    box-shadow: none;
  }

  .menu-header {
    border-bottom: 1px solid #dbe3ef;
    padding-bottom: 0.85rem;
  }

  .brand-lockup {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }

  .brand-logo {
    width: 3.25rem;
    height: 3.25rem;
    object-fit: contain;
    flex: 0 0 auto;
    filter: none;
  }

  .eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
    color: #b91c1c;
    margin-bottom: 0.5rem;
  }

  .legal-notes p + p {
    margin-top: 0.35rem;
  }

  .section-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 0.5rem;
    border: 1px solid #e2e8f0;
    color: #334155;
    box-shadow: none;
  }

  .menu-shell,
  .menu-shell *,
  .menu-shell *::before,
  .menu-shell *::after {
    box-shadow: none !important;
    filter: none !important;
    text-shadow: none !important;
  }

  .menu-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }

  .menu-table .col-drink {
    width: 60%;
  }

  .menu-table .col-volume,
  .menu-table .col-price {
    width: 20%;
  }

  .menu-table thead th {
    font-size: 0.78rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: #475569;
    font-weight: 700;
    border-bottom: 2px solid #cbd5e1;
    padding: 0.65rem 0.5rem;
    text-align: left;
  }

  .menu-table thead th:last-child,
  .menu-table tbody td:last-child {
    text-align: right;
  }

  .menu-table tbody th,
  .menu-table tbody td {
    border-bottom: 1px solid #e2e8f0;
    padding: 0.7rem 0.5rem;
    color: #0f172a;
  }

  .menu-table tbody th {
    font-weight: 600;
    text-align: left;
  }

  .menu-table thead th:first-child,
  .menu-table tbody th:first-child {
    text-align: left;
  }

  .menu-table tbody tr:last-child th,
  .menu-table tbody tr:last-child td {
    border-bottom: none;
  }

  .menu-table tbody tr:nth-child(odd) {
    background: rgb(248 250 252 / 0.65);
  }

  @media (max-width: 767px) {
    .brand-lockup {
      align-items: flex-start;
    }

    .brand-logo {
      width: 2.75rem;
      height: 2.75rem;
    }

    .menu-table .col-drink {
      width: 54%;
    }

    .menu-table .col-volume,
    .menu-table .col-price {
      width: 23%;
    }

    .menu-table thead th,
    .menu-table tbody th,
    .menu-table tbody td {
      font-size: 0.92rem;
      padding: 0.58rem 0.38rem;
    }
  }

  @page {
    size: A4;
    margin: 8mm;
  }

  @media print {
    :global(html),
    :global(body),
    :global(.app),
    :global(.app > main) {
      background: #ffffff !important;
      margin: 0 !important;
      padding: 0 !important;
    }

    :global(body > .skip-links),
    :global(.app > header),
    :global(.app > footer),
    :global(#mobile-backdrop),
    :global(#mobile-menu) {
      display: none !important;
    }

    :global(.app > main) {
      padding: 0 !important;
      margin: 0 !important;
    }

    :global(.app > main > *) {
      display: none !important;
    }

    :global(.app > main > .container) {
      display: block !important;
    }

    :global(.app > main),
    :global(.app > main *) {
      box-shadow: none !important;
      text-shadow: none !important;
      filter: none !important;
    }

    .screen-only {
      display: none !important;
    }

    .container {
      max-width: none;
      width: 100% !important;
      padding: 0 !important;
      margin: 0 !important;
    }

    .grid {
      gap: 0.7rem !important;
    }

    .menu-shell {
      border: none;
      border-radius: 0;
      padding: 0;
      box-shadow: none;
      background: #ffffff;
    }

    .menu-header {
      border-bottom: 2px solid #334155;
      margin-bottom: 0.8rem;
      padding-bottom: 0.55rem;
    }

    .brand-logo {
      width: 2.2rem;
      height: 2.2rem;
      filter: none;
    }

    .brand-lockup {
      gap: 0.7rem;
    }

    .eyebrow {
      margin-bottom: 0.25rem;
      font-size: 8.6pt;
      letter-spacing: 0.06em;
    }

    .menu-header h2 {
      font-size: 18.5pt;
      line-height: 1.1;
      margin: 0;
    }

    .menu-header p.mt-2 {
      display: none;
    }

    .print-section {
      break-inside: avoid;
      page-break-inside: avoid;
    }

    .print-section > div {
      border: 1px solid #d6deea;
      border-radius: 0;
      padding-left: 0.55rem;
      padding-right: 0.55rem;
      padding-bottom: 0.28rem;
    }

    .print-section > div > .py-3 {
      padding-top: 0.45rem;
      padding-bottom: 0.35rem;
    }

    .section-icon {
      width: 1.3rem;
      height: 1.3rem;
      border: none;
      box-shadow: none;
    }

    .menu-table thead th {
      font-size: 8.7pt;
      padding: 0.38rem 0.34rem;
    }

    .menu-table tbody tr:not(.section-row) th,
    .menu-table tbody tr:not(.section-row) td {
      font-size: 11pt;
      padding: 0.4rem 0.34rem;
      line-height: 1.24;
    }

    .menu-table tbody tr:nth-child(odd) {
      background: transparent;
    }

    .legal-notes {
      display: none;
    }
  }
</style>

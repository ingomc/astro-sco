---
import App from "../layouts/App.astro";
import HpCard from "../components/HpCard.astro";
import HpStage from "../components/HpStage.astro";

const title = "Getränkekarte - SCO-OGV Oberfüllbach";
const description = "Aktuelle Getränkekarte im Sportheim des SCO-OGV Oberfüllbach.";

const sectionMeta = {
  Bier: { icon: "beer" },
  "Alkoholfreie Getränke": { icon: "bottle" },
  "Wein und Spirituosen": { icon: "glass" }
} as const;

const slugify = (value: string) =>
  value
    .toLowerCase()
    .replaceAll("ä", "ae")
    .replaceAll("ö", "oe")
    .replaceAll("ü", "ue")
    .replaceAll("ß", "ss")
    .replaceAll(" ", "-");

const menuSections = [
  {
    name: "Bier",
    rows: [
      { drink: "Bier, Radler, Weizen", volume: "1,0 l", price: "50,70 EUR" },
      { drink: "Bier, Radler, Weizen", volume: "0,5 l", price: "3,00 EUR" },
      { drink: "Bier, Radler, Weizen", volume: "0,25 l", price: "1,70 EUR" },
      { drink: "Leichtbier, alkoholfreies Weizenbier", volume: "0,5 l", price: "3,00 EUR" }
    ]
  },
  {
    name: "Alkoholfreie Getränke",
    rows: [
      { drink: "Limo, Spezi", volume: "0,5 l", price: "2,50 EUR" },
      { drink: "Cola", volume: "0,5 l", price: "2,50 EUR" },
      { drink: "Apfelsaftschorle", volume: "0,5 l", price: "2,50 EUR" },
      { drink: "Mineralwasser", volume: "0,5 l", price: "2,50 EUR" }
    ]
  },
  {
    name: "Wein und Spirituosen",
    rows: [
      { drink: "Frankenwein, Rotwein", volume: "0,2 l", price: "2,70 EUR" },
      { drink: "Frankenwein, Rotwein", volume: "0,1 l", price: "1,40 EUR" },
      { drink: "Weinschorle", volume: "0,5 l", price: "3,50 EUR" },
      { drink: "Weinschorle", volume: "0,25 l", price: "1,80 EUR" },
      { drink: "Schnaps", volume: "0,02 l", price: "1,50 EUR" }
    ]
  }
] as const;

type PrintMenuRow =
  | { section: string }
  | {
      drink: string;
      volumes: string[];
      prices: string[];
    };

const groupPrintRows = (
  rows: readonly { drink: string; volume: string; price: string }[]
): Exclude<PrintMenuRow, { section: string }>[] => {
  return rows.reduce<Exclude<PrintMenuRow, { section: string }>[]>((acc, row) => {
    const last = acc.at(-1);

    if (last && last.drink === row.drink) {
      last.volumes.push(row.volume);
      last.prices.push(row.price);
      return acc;
    }

    acc.push({
      drink: row.drink,
      volumes: [row.volume],
      prices: [row.price]
    });

    return acc;
  }, []);
};

const printRows: PrintMenuRow[] = menuSections.flatMap((section) => [
  { section: section.name },
  ...groupPrintRows(section.rows)
]);

const isPrintSectionRow = (row: PrintMenuRow): row is { section: string } => "section" in row;
---

<App title={title} description={description}>
  <div class="screen-only">
    <HpStage image="/src/media/buehne-sportheim.jpg" title="Getränkekarte" />
  </div>

  <div class="container mx-auto px-4 py-6 md:py-10">
    <div class="menu-shell rounded-2xl border border-slate-200 p-4 md:p-8">
      <header class="mb-6 md:mb-8">
        <div class="menu-header">
          <div class="brand-lockup">
            <img
              src="/assets/logo_sco.png"
              alt="SCO-OGV Oberfüllbach Logo"
              class="brand-logo"
              loading="eager"
              decoding="async"
            />
            <div>
              <p class="eyebrow">Sportheim SCO-OGV Oberfüllbach</p>
              <h2 class="text-2xl md:text-3xl font-bold text-slate-900">Getränkekarte</h2>
              <p class="mt-2 max-w-2xl text-slate-700">
                Frisch, fair und unkompliziert - für Spieltag, Feier und gemütliches Beisammensein.
              </p>
            </div>
          </div>
        </div>
      </header>

      <div class="grid gap-4 md:gap-6" role="list" aria-label="Getränkekarte nach Kategorien">
        {
          menuSections.map((section) => {
            const id = `section-${slugify(section.name)}`;
            const meta = sectionMeta[section.name];

            return (
            <section role="listitem" aria-labelledby={id} class="print-section">
              <HpCard>
                <div slot="title" class="flex items-center justify-between gap-3">
                  <h3 id={id} class="flex items-center gap-2 font-bold text-lg text-slate-900">
                    <span class="section-icon" aria-hidden="true">
                      {
                        meta.icon === "beer" && (
                          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M6 6h8v10a3 3 0 0 1-3 3H9a3 3 0 0 1-3-3z"></path>
                            <path d="M14 9h2a2 2 0 0 1 0 4h-2"></path>
                            <path d="M8 4v2M11 4v2"></path>
                          </svg>
                        )
                      }
                      {
                        meta.icon === "bottle" && (
                          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M10 3h4"></path>
                            <path d="M11 3v3l-3 4v8a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2v-8l-3-4V3"></path>
                          </svg>
                        )
                      }
                      {
                        meta.icon === "glass" && (
                          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M7 4h10l-2 7a3 3 0 0 1-3 2 3 3 0 0 1-3-2z"></path>
                            <path d="M12 13v5"></path>
                            <path d="M9 20h6"></path>
                          </svg>
                        )
                      }
                    </span>
                    {section.name}
                  </h3>
                </div>

                <div class="overflow-x-auto">
                  <table class="menu-table">
                    <caption class="sr-only">{section.name}</caption>
                    <colgroup>
                      <col class="col-drink" />
                      <col class="col-volume" />
                      <col class="col-price" />
                    </colgroup>
                    <thead>
                      <tr>
                        <th scope="col">Getränk</th>
                        <th scope="col">Menge</th>
                        <th scope="col" class="text-right">Preis</th>
                      </tr>
                    </thead>
                    <tbody>
                      {
                        section.rows.map((row) => (
                          <tr>
                            <th scope="row">{row.drink}</th>
                            <td>{row.volume}</td>
                            <td class="text-right whitespace-nowrap">{row.price}</td>
                          </tr>
                        ))
                      }
                    </tbody>
                  </table>
                </div>
              </HpCard>
            </section>
          )})
        }
      </div>

      <footer class="mt-6 md:mt-8 border-t border-slate-200 pt-4 text-sm text-slate-600 legal-notes" aria-label="Rechtliche Hinweise">
        <p>Alle Preise in EUR inkl. gesetzlicher MwSt. Stand: 14. Mai 2026. Änderungen und Irrtümer vorbehalten.</p>
        <p>Die Angaben auf dieser Website sind unverbindlich; maßgeblich ist die vor Ort ausgehängte Getränkekarte.</p>
        <p>Informationen zu Allergenen und Zusatzstoffen erhalten Sie beim Personal.</p>
        <p>Ausschank alkoholischer Getränke gemäß Jugendschutzgesetz.</p>
      </footer>

    </div>

    <article class="print-menu" hidden aria-label="Getränkekarte Druckansicht">
      <header class="print-menu-head">
        <img src="/assets/logo_sco.png" alt="SCO-OGV Oberfüllbach Logo" class="print-logo-left" />

        <div class="print-title-wrap">
          <p class="print-kicker">Sportheim SCO-OGV Oberfüllbach</p>
          <h1>Getränkekarte</h1>
          <p class="print-darts-note">Sonntags ab 18 Uhr: Steel-Darts auf 5 Scheiben. Gäste sind herzlich willkommen, bitte kurz vorher anmelden.</p>
        </div>

        <img
          src="/sco-fuelltreffer.png"
          alt="SCO Fulltreffer Darts Logo"
          class="print-logo-right"
          loading="eager"
          decoding="async"
        />
      </header>

      <div class="print-menu-sheet">
        <table class="print-table" aria-label="Getränke und Preise">
          <tbody>
            {
              printRows.map((row) =>
                isPrintSectionRow(row) ? (
                  <tr class="print-section-row">
                    <th scope="colgroup" colspan="3">{row.section}</th>
                  </tr>
                ) : (
                  <tr>
                    <th scope="row" class="print-drink">{row.drink}</th>
                    <td>
                      {row.volumes.map((volume) => <div class="stacked">{volume}</div>)}
                    </td>
                    <td class="text-right">
                      {row.prices.map((price) => <div class="stacked">{price}</div>)}
                    </td>
                  </tr>
                )
              )
            }
          </tbody>
        </table>
      </div>

      <p class="print-greeting">
        <span class="greet-line">Einen angenehmen Aufenthalt wünscht Ihnen der</span>
        <span class="greet-club"><span class="nowrap">SCO&nbsp;&amp;&nbsp;OGV</span> Oberfüllbach</span>
      </p>

      <footer class="print-legal" aria-label="Rechtliche Hinweise Druckansicht">
        <div class="print-legal-text">
          <p class="print-web-note">Mehr Infos, Termine &amp; Events: <span class="nowrap">www.sc-oberfuellbach.de</span></p>
          <p>Alle Preise in EUR inkl. gesetzlicher MwSt. Stand: 14. Mai 2026. Änderungen und Irrtümer vorbehalten. Informationen zu Allergenen und Zusatzstoffen erhalten Sie beim Personal. Ausschank alkoholischer Getränke gemäß Jugendschutzgesetz.</p>
        </div>
        <aside class="print-qr" aria-label="QR-Code zur Website">
          <img
            src="https://api.qrserver.com/v1/create-qr-code/?size=180x180&data=https%3A%2F%2Fwww.sc-oberfuellbach.de%2F%3Futm_source%3Dgetraenkekarte%26utm_medium%3Dqr%26utm_campaign%3Dprint"
            alt="QR-Code zur Website sc-oberfuellbach.de"
            loading="eager"
            decoding="async"
          />
          <p>Jetzt online</p>
        </aside>
      </footer>
    </article>
  </div>
</App>

<style>
  .screen-only {
    display: block;
  }

  .print-menu {
    display: none;
  }

  .nowrap {
    white-space: nowrap;
  }

  .menu-shell {
    background: #ffffff;
    box-shadow: none;
  }

  .menu-header {
    border-bottom: 1px solid #dbe3ef;
    padding-bottom: 0.85rem;
  }

  .brand-lockup {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }

  .brand-logo {
    width: 3.25rem;
    height: 3.25rem;
    object-fit: contain;
    flex: 0 0 auto;
    filter: none;
  }

  .eyebrow {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
    color: #b91c1c;
    margin-bottom: 0.5rem;
  }

  .legal-notes p + p {
    margin-top: 0.35rem;
  }

  .section-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 0.5rem;
    border: 1px solid #e2e8f0;
    color: #334155;
    box-shadow: none;
  }

  .menu-shell,
  .menu-shell *,
  .menu-shell *::before,
  .menu-shell *::after {
    box-shadow: none !important;
    filter: none !important;
    text-shadow: none !important;
  }

  .menu-table {
    width: 100%;
    border-collapse: collapse;
    table-layout: fixed;
  }

  .menu-table .col-drink {
    width: 60%;
  }

  .menu-table .col-volume,
  .menu-table .col-price {
    width: 20%;
  }

  .menu-table thead th {
    font-size: 0.78rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: #475569;
    font-weight: 700;
    border-bottom: 2px solid #cbd5e1;
    padding: 0.65rem 0.5rem;
    text-align: left;
  }

  .menu-table thead th:last-child,
  .menu-table tbody td:last-child {
    text-align: right;
  }

  .menu-table tbody th,
  .menu-table tbody td {
    border-bottom: 1px solid #e2e8f0;
    padding: 0.7rem 0.5rem;
    color: #0f172a;
  }

  .menu-table tbody th {
    font-weight: 600;
    text-align: left;
  }

  .menu-table thead th:first-child,
  .menu-table tbody th:first-child {
    text-align: left;
  }

  .menu-table tbody tr:last-child th,
  .menu-table tbody tr:last-child td {
    border-bottom: none;
  }

  .menu-table tbody tr:nth-child(odd) {
    background: rgb(248 250 252 / 0.65);
  }

  @media (max-width: 767px) {
    .brand-lockup {
      align-items: flex-start;
    }

    .brand-logo {
      width: 2.75rem;
      height: 2.75rem;
    }

    .menu-table .col-drink {
      width: 54%;
    }

    .menu-table .col-volume,
    .menu-table .col-price {
      width: 23%;
    }

    .menu-table thead th,
    .menu-table tbody th,
    .menu-table tbody td {
      font-size: 0.92rem;
      padding: 0.58rem 0.38rem;
    }
  }

  @page {
    size: A4;
    margin: 8mm;
  }

  @media print {
    :global(html),
    :global(body),
    :global(.app),
    :global(.app > main) {
      background: #ffffff !important;
      margin: 0 !important;
      padding: 0 !important;
    }

    :global(body > .skip-links),
    :global(.app > header),
    :global(.app > footer),
    :global(#mobile-backdrop),
    :global(#mobile-menu) {
      display: none !important;
    }

    :global(.app > main) {
      padding: 0 !important;
      margin: 0 !important;
    }

    :global(.app > main > *) {
      display: none !important;
    }

    :global(.app > main > .container) {
      display: block !important;
    }

    :global(.app > main),
    :global(.app > main *) {
      box-shadow: none !important;
      text-shadow: none !important;
      filter: none !important;
    }

    .screen-only {
      display: none !important;
    }

    .container {
      max-width: none;
      width: 100% !important;
      padding: 0 !important;
      margin: 0 !important;
    }

    .menu-shell {
      display: none;
    }

    .print-menu {
      display: block;
      padding: 1.2mm 1.6mm 0;
    }

    .print-menu[hidden] {
      display: block !important;
    }

    .print-menu-head {
      display: grid;
      grid-template-columns: 0.9fr 2.4fr 0.9fr;
      align-items: start;
      gap: 2.8mm;
    }

    .print-title-wrap {
      text-align: center;
      padding-top: 0.8mm;
    }

    .print-kicker {
      margin: 0;
      font-size: 9pt;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #b91c1c;
      font-weight: 700;
    }

    .print-title-wrap h1 {
      margin: 0.2mm 0 0;
      font-size: 30pt;
      line-height: 1.05;
      font-weight: 900;
      letter-spacing: 0.01em;
      color: #000;
    }

    .print-darts-note {
      margin: 0.6mm 0 0;
      font-size: 9.8pt;
      line-height: 1.22;
      color: #334155;
      font-weight: 600;
    }

    .print-logo-left,
    .print-logo-right {
      justify-self: center;
      width: 24mm;
      height: auto;
      max-height: 24mm;
      object-fit: contain;
    }

    .print-menu-sheet {
      margin: 4.5mm auto 0;
      width: min(175mm, 100%);
      background: #fff;
      border: 1px solid #d6d3d1;
      padding: 4.5mm 5mm;
    }

    .print-table {
      width: 100%;
      border-collapse: collapse;
      table-layout: fixed;
    }

    .print-table th,
    .print-table td {
      font-size: 14.3pt;
      line-height: 1.32;
      padding: 1.85mm 1.2mm;
      color: #111;
      vertical-align: top;
      text-align: left;
    }

    .print-table td:last-child,
    .print-table .text-right {
      text-align: right;
    }

    .print-drink {
      width: 56%;
      font-weight: 800;
    }

    .print-table tbody tr:not(.print-section-row) th,
    .print-table tbody tr:not(.print-section-row) td {
      border-bottom: 0.35mm solid #d7dee8;
    }

    .print-table tbody tr:last-child th,
    .print-table tbody tr:last-child td {
      border-bottom: none;
    }

    .print-section-row th {
      border-top: 0.7mm solid #b8c5d6;
      border-bottom: 0.35mm solid #d7dee8;
      padding-top: 4.6mm;
      padding-bottom: 2.1mm;
      font-size: 9.6pt;
      font-weight: 800;
      color: #b91c1c;
      letter-spacing: 0.07em;
      text-transform: uppercase;
    }

    .print-table tbody tr.print-section-row:not(:first-child) th {
      padding-top: 5.8mm;
    }

    .print-table tbody tr.print-section-row + tr th,
    .print-table tbody tr.print-section-row + tr td {
      padding-top: 2.4mm;
    }

    .print-table tbody tr.print-section-row:first-child th {
      border-top: none;
      padding-top: 1.6mm;
    }

    .stacked + .stacked {
      margin-top: 1.1mm;
    }

    .print-greeting {
      margin: 8mm auto 0;
      max-width: 140mm;
      text-align: center;
      font-size: 15.8pt;
      line-height: 1.25;
      color: #111827;
    }

    .print-greeting .greet-line,
    .print-greeting .greet-club {
      display: block;
    }

    .print-greeting .greet-line {
      font-weight: 500;
    }

    .print-greeting .greet-club {
      margin-top: 1.2mm;
      font-size: 17.6pt;
      font-weight: 900;
      letter-spacing: 0.01em;
    }

    .print-legal {
      margin: 6mm auto 0;
      width: min(175mm, 100%);
      font-size: 8.4pt;
      line-height: 1.28;
      color: #64748b;
      display: grid;
      grid-template-columns: 1fr 24mm;
      gap: 4mm;
      align-items: end;
    }

    .print-legal-text {
      align-self: end;
    }

    .print-web-note {
      margin: 0 0 2.2mm;
      font-size: 10pt;
      line-height: 1.2;
      font-weight: 800;
      color: #b91c1c;
      letter-spacing: 0.015em;
    }

    .print-legal-text p {
      margin: 0;
    }

    .print-legal-text p + p {
      margin-top: 1.1mm;
    }

    .print-qr {
      margin: 0;
      text-align: center;
    }

    .print-qr img {
      width: 24mm;
      height: 24mm;
      display: block;
      border: 0.25mm solid #cbd5e1;
    }

    .print-qr p {
      margin: 1mm 0 0;
      font-size: 7.2pt;
      line-height: 1.1;
      color: #64748b;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-weight: 700;
    }

    .grid {
      gap: 0.7rem !important;
    }

    .menu-shell {
      border: none;
      border-radius: 0;
      padding: 0;
      box-shadow: none;
      background: #ffffff;
    }

    .menu-header {
      border-bottom: 2px solid #334155;
      margin-bottom: 0.8rem;
      padding-bottom: 0.55rem;
    }

    .brand-logo {
      width: 2.2rem;
      height: 2.2rem;
      filter: none;
    }

    .brand-lockup {
      gap: 0.7rem;
    }

    .eyebrow {
      margin-bottom: 0.25rem;
      font-size: 8.6pt;
      letter-spacing: 0.06em;
    }

    .menu-header h2 {
      font-size: 18.5pt;
      line-height: 1.1;
      margin: 0;
    }

    .menu-header p.mt-2 {
      display: none;
    }

    .print-section {
      break-inside: avoid;
      page-break-inside: avoid;
    }

    .print-section > div {
      border: 1px solid #d6deea;
      border-radius: 0;
      padding-left: 0.55rem;
      padding-right: 0.55rem;
      padding-bottom: 0.28rem;
    }

    .print-section > div > .py-3 {
      padding-top: 0.45rem;
      padding-bottom: 0.35rem;
    }

    .section-icon {
      width: 1.3rem;
      height: 1.3rem;
      border: none;
      box-shadow: none;
    }

    .menu-table thead th {
      font-size: 8.7pt;
      padding: 0.38rem 0.34rem;
    }

    .menu-table tbody tr:not(.section-row) th,
    .menu-table tbody tr:not(.section-row) td {
      font-size: 12.5pt;
      padding: 0.43rem 0.34rem;
      line-height: 1.26;
    }

    .menu-table tbody tr:nth-child(odd) {
      background: transparent;
    }

    .legal-notes {
      display: none;
    }
  }
</style>

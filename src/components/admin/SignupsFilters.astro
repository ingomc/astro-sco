    <label data-wide="true">Suche
      <input id="q" type="text" placeholder="Name oder E-Mail" />
    </label>
    <label data-wide="true">Event
      <input id="eventId" type="text" placeholder="z.B. kerwa-2026" />
    </label>
    <label>Typ

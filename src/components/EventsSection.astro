---
import { Image } from 'astro:assets';
import FormattedDate from "./FormattedDate.astro";
import BadgeMini from "./BadgeMini.astro";

// Responsive Event-Karte für Veranstaltungsseite: mobil vertikal, Desktop horizontal
const { data, path } = Astro.props;
const images = import.meta.glob<{ default: ImageMetadata }>('/public/assets/**/*.{jpeg,jpg,png,gif,avif}');
---

<div>
    <ul class="grid grid-cols-1 gap-4">
      {
        data.map((event) => {
          const href = `/${path ? path : 'veranstaltungen' }/${event.slug}/`;
          return (
          <li>
            <a
              class="flex flex-col md:flex-row w-full bg-white rounded-lg border border-slate-300 transition-all duration-200 p-0 md:p-4 overflow-hidden hover:shadow focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-red-700 focus-visible:ring-offset-2"
              href={href}
              aria-label={`Veranstaltung ansehen: ${event.data.title} am ${event.data.eventDate.toLocaleDateString("de-DE")}`}
            >
              {event.data.heroImage && (
                <div class="shrink-0 overflow-hidden w-full md:w-80 md:rounded">
                  <Image
                    width={600}
                    height={400}
                    alt={event.data.title}
                    src={images[`/public${event.data.heroImage}`]()}
                    widths={[300, 400, 600]}
                    sizes="(max-width: 768px) 100vw, 320px"
                    class="object-contain object-top w-full h-auto"
                  />
                </div>
              )}
              <div class="flex flex-col justify-between w-full min-w-0 gap-2 md:gap-3 p-4 md:p-0 md:pl-4">
                <div class="flex flex-col gap-2">
                  <h2 class="font-bold text-lg md:text-xl hyphens-auto break-words" lang="de">{event.data.title}</h2>
                  <div class="flex flex-wrap gap-2 md:gap-4 gap-y-1 md:gap-y-2">
                    <BadgeMini>
                      <b>Am:</b>
                      {event.data.eventDate.toLocaleDateString("de-DE", {
                        weekday: "short",
                      })}
                      ,
                      <FormattedDate
                        date={event.data.eventDate}
                        time={false}
                      />
                    </BadgeMini>
                    {event.data.location && (
                      <BadgeMini>
                        <strong>Ort:</strong> {event.data.location}
                      </BadgeMini>
                    )}
                  </div>
                </div>
                <p><small>{event.data.description}</small></p>
                <span class:list={[
                  "self-end text-xs text-center font-semibold inline-flex gap-2 items-center py-1.5 px-3 md:py-2 md:px-4 justify-center rounded-full",
                  event.data.cta ? "bg-red-700 text-white hover:bg-red-800" : "bg-slate-100 hover:bg-slate-300"
                ]}>
                  {event.data.cta ? event.data.cta : 'Mehr erfahren'}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 256 256"
                    aria-hidden="true"
                  >
                    <path
                      fill="currentColor"
                      d="m224.49 136.49l-72 72a12 12 0 0 1-17-17L187 140H40a12 12 0 0 1 0-24h147l-51.49-51.52a12 12 0 0 1 17-17l72 72a12 12 0 0 1-.02 17.01Z"
                    />
                  </svg>
                </span>
              </div>
            </a>
          </li>
        )})
      }
    </ul>
  </div>